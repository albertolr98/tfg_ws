<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">


    <!-- Base Footprint para paquetes de navegacion -->
    <link name="base_footprint">
        <origin xyz="0 0 0" rpy="0 0 0"/>        
    </link>    
    
    <!-- Base Link del que se referencian el resto de elementos -->
    <link name ="base_link">
        <visual>
            <geometry>
                <mesh filename="file://$(find ow_peque_description)/meshes/EnsamblajeRobotPeque.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <origin xyz="0 0 ${base_to_ground_height}" rpy="${pi / 2.0} 0 ${-2.0 * pi / 3.0}"/>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <mesh filename="file://$(find ow_peque_description)/meshes/EnsamblajeRobotPeque.stl" scale="0.001 0.001 0.001"/>

                <!--cylinder radius="${base_radius}" length="${corner_height - corner_shaft_height }"/-->
            </geometry>
            <origin xyz="0 0 ${base_to_ground_height}" rpy="${pi / 2.0} 0 ${-2.0 * pi / 3.0}"/>
        </collision>
         <inertial>
            <mass value="5"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.0004055" ixy="0" ixz="0" iyy="0.0004055" iyz="0" izz="0"/>
        </inertial>
    </link>


    <!-- Ruedas omnidireccionales -->
    <xacro:include filename="$(find ow_peque_description)/urdf/omniwheel.xacro"/>
    <xacro:omniwheel parent_link="base_link" 
                     prefix="front" 
                     base_radius="${base_radius}"
                     z_offset="${ground_to_shaft_height}"
                     angle="${pi / 2.0}"/>
      
    <xacro:omniwheel parent_link="base_link"
                     prefix="left" 
                     base_radius="${base_radius}"
                     z_offset="${ground_to_shaft_height}"
                     angle="${pi + pi / 6.0}"/>

    <xacro:omniwheel parent_link="base_link"
                     prefix="right"
                     base_radius="${base_radius}"
                     z_offset="${ground_to_shaft_height}"
                     angle="${- pi / 6.0}"/>
    

    <!-- Joints -->
    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 ${omniwheel_radius}" rpy="0 0 0"/>
    </joint>


</robot>
