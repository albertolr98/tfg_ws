<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="omniwheel" params="parent_link prefix angle base_radius z_offset">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <mesh filename="file://$(find ow_peque_description)/meshes/RuedaOmnidireccional.stl" scale="0.001 0.001 0.001"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 ${pi / 2.0}"/>
                <material name="grey"/>
            </visual>
            <inertial>
                <mass value="0.582"/>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <inertia ixx="0.0005937" ixy="0" ixz="0" iyy="0.0005937" iyz="0" izz="0.0009841"/>
            </inertial>
            <collision>
                <geometry>
                    <!-- Para que sea más sencilla la simulación, se usa una geometría cilíndrica en lugar de la malla -->
                    <cylinder radius="0.029" length="0.02"/>
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
            </collision>
        </link>

        <joint name="base_${prefix}_wheel_joint" type="continuous">
            <parent link="${parent_link}"/>
            <child link="${prefix}_wheel_link"/>
            <origin xyz="${cos (angle) * base_radius} ${sin (angle) * base_radius} ${z_offset}" rpy="0 0 ${angle - pi / 2.0}"/>
            <axis xyz="0 1 0"/>
        </joint>
    </xacro:macro>

</robot>
